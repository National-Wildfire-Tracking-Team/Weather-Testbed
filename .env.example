# Copy this file to `.env.local` (git-ignored) and set your own token.
#
# Public Mapbox token (starts with "pk."). Used from the browser, so it must be
# a public token — never a secret ("sk.") token.
# Manage tokens at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_public_token_here
